# PostgreSQL 部署配置示例 - 编译模式
#
# 重要说明：
# 1. 编译模式必须指定 pg_source (PostgreSQL 源码包路径)
# 2. 如果使用 Patroni 模式或启用 Citus 插件，必须指定 plugin_source_citus
# 3. 所有路径支持相对路径和绝对路径
# 4. 相对路径相对于脚本所在目录

# SSH 配置
ssh_user: root
# ssh_password: your_password  # 可选，推荐使用 SSH 密钥认证

# 部署模式: single/master-slave/patroni/multi-group
deploy_mode: master-slave

# 构建模式: compile/distribute
build_mode: compile

# PostgreSQL 源码包路径 (编译模式必填)
# 必须是 .tar.gz 或 .tgz 格式
pg_source: /path/to/postgresql-17.9.tar.gz
# 或使用相对路径（相对于脚本目录）
# pg_source: ./postgresql-17.9.tar.gz

# 编译参数 (可选)
pg_configure: --enable-debug CFLAGS='-O2' --with-zstd --with-lz4

# 要编译的插件 (可选，逗号分隔)
# 可选值: citus, pg_stat_statements, auto_explain
compile_plugins: citus

# Citus 源码包路径 (当使用 Patroni 模式或启用 citus 插件时必填)
plugin_source_citus: /path/to/citus-12.1.tar.gz
# 或使用相对路径
# plugin_source_citus: ./citus-12.1.tar.gz

# 软件安装目录
pg_soft_dir: /usr/local/pgsql

# 日志目录
log_dir: /data/pglog

# Patroni 配置目录 (Patroni 模式使用)
patroni_conf_dir: /etc/patroni

# 运行用户
pg_user: postgres

# 复制用户
replication_user: replicator

# 超时配置
timeout_pg_ready: 60
timeout_patroni_ready: 60
timeout_basebackup: 300
timeout_scp: 600

# 组配置
# 格式: id|name|role|ip:port:data_dir:wal_dir:pglog_dir:is_master,...
# wal_dir 和 pglog_dir 留空使用 "-"
# 多个节点用逗号分隔
group_0: 0|pg_replicate|primary|192.168.1.10:5432:/data/pgdata::::1,192.168.1.11:5432:/data/pgdata::::0
