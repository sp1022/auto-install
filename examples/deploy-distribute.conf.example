# PostgreSQL 部署配置示例 - 分发模式
#
# 重要说明：
# 1. 分发模式必须预先编译好 PostgreSQL 并打包为 tar.gz
# 2. 必须指定 distribute_file (PostgreSQL 分发包路径)
# 3. 如何准备分发包：
#    cd /usr/local/pgsql
#    tar -czf /tmp/pgsql-17.9-bin.tar.gz .
# 4. 分发包应包含完整的 PostgreSQL 安装目录（bin/, lib/, share/ 等）

# SSH 配置
ssh_user: root
# ssh_password: your_password  # 可选，推荐使用 SSH 密钥认证

# 部署模式: single/master-slave/patroni/multi-group
deploy_mode: master-slave

# 构建模式: distribute
build_mode: distribute

# PostgreSQL 分发包路径 (分发模式必填)
# 必须是 .tar.gz 或 .tgz 格式
# 必须是预先编译好的 PostgreSQL 二进制包
distribute_file: /path/to/pgsql-17.9-bin.tar.gz
# 或使用相对路径（相对于脚本目录）
# distribute_file: ./pgsql-17.9-bin.tar.gz

# 软件安装目录
pg_soft_dir: /usr/local/pgsql

# 日志目录
log_dir: /data/pglog

# Patroni 配置目录 (Patroni 模式使用)
patroni_conf_dir: /etc/patroni

# 运行用户
pg_user: postgres

# 复制用户
replication_user: replicator

# 超时配置
timeout_pg_ready: 60
timeout_patroni_ready: 60
timeout_basebackup: 300
timeout_scp: 600

# 组配置
# 格式: id|name|role|ip:port:data_dir:wal_dir:pglog_dir:is_master,...
# wal_dir 和 pglog_dir 留空使用 "-"
# 多个节点用逗号分隔
group_0: 0|pg_replicate|primary|192.168.1.10:5432:/data/pgdata::::1,192.168.1.11:5432:/data/pgdata::::0
